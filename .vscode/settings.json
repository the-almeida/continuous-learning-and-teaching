{
  "typescript.tsdk": "node_modules/typescript/lib",

  "eslint.enable": true,
  "eslint.run": "onSave",
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  }
}
